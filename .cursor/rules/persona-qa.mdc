## Circuit Breaker Test Requirements

Any change to `app/llm/circuit_breaker.py` requires these tests to pass:

```python
def test_opens_after_threshold()          # 3 failures → state == "open"
def test_blocks_when_open()               # open state → raises immediately, no call
def test_half_open_after_timeout()        # elapsed > 60s → state == "half_open"
def test_closes_on_half_open_success()    # probe succeeds → state == "closed", failures == 0
def test_reopens_on_half_open_failure()   # probe fails → state == "open"
def test_fallback_used_when_open()        # gateway uses next provider when breaker open
def test_all_providers_down_raises()      # all breakers open → AllProvidersDown
```

---

## Skill Test Requirements

Any new skill must ship with:

```python
# 1. Successful execution test
async def test_{skill_name}_success(mock_http):
    mock_http.return_value = build_mock_response(...)
    result = await skill.execute("tool_name", valid_params)
    assert result.success is True
    assert result.data is not None

# 2. HTTP failure test
async def test_{skill_name}_handles_http_error(mock_http):
    mock_http.side_effect = httpx.TimeoutException("timeout")
    result = await skill.execute("tool_name", valid_params)
    assert result.success is False
    assert result.error is not None

# 3. Unknown tool test
async def test_{skill_name}_unknown_tool():
    result = await skill.execute("nonexistent_tool", {})
    assert result.success is False
    assert "Unknown tool" in result.error

# 4. Timeout enforcement (via SkillExecutor)
async def test_{skill_name}_times_out():
    executor = SkillExecutor()
    executor.DEFAULT_TIMEOUT = 0.01
    result = await executor.run(SlowVersionOfSkill(), "tool_name", {})
    assert result.success is False
    assert "timed out" in result.error.lower()
```

