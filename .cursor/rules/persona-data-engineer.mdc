## Archival Job (runs daily at 3am)

Entries older than 30 days are summarized into a compact archive entry,
then the originals are soft-deleted. This keeps the episodic store queryable
without unbounded growth.

```python
async def archive_old_entries(db: AsyncSession, days: int = 30):
    cutoff = datetime.now(UTC) - timedelta(days=days)

    # Fetch old entries grouped by session
    old = await db.execute(
        select(EpisodicMemory)
        .where(EpisodicMemory.created_at < cutoff)
        .where(EpisodicMemory.archived_at.is_(None))
        .where(EpisodicMemory.deleted_at.is_(None))
        .order_by(EpisodicMemory.session_id, EpisodicMemory.created_at)
    )
    entries = old.scalars().all()
    if not entries:
        return

    # Summarize with LLM, store as single archive entry
    summary = await summarize_entries(entries)  # LLM call
    archive = EpisodicMemory(
        session_id="archive",
        role="archive_summary",
        content=summary,
        source="archival_job",
    )
    db.add(archive)

    # Soft-delete originals
    for entry in entries:
        entry.archived_at = datetime.now(UTC)

    await db.commit()
    log.info("episodic_archived", count=len(entries))
```

