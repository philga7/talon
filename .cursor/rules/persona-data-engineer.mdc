## Database Schema

### episodic_memory table
```sql
CREATE TABLE episodic_memory (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    session_id  VARCHAR(128) NOT NULL,
    role        VARCHAR(32)  NOT NULL,  -- 'user', 'assistant', 'memory_import'
    content     TEXT         NOT NULL,
    embedding   VECTOR(1536),           -- pgvector, nullable (set async)
    source      VARCHAR(64)  DEFAULT 'chat',
    created_at  TIMESTAMPTZ  DEFAULT NOW(),
    archived_at TIMESTAMPTZ,            -- NULL = active
    deleted_at  TIMESTAMPTZ             -- NULL = not deleted
);

-- HNSW index for approximate nearest-neighbor search
CREATE INDEX episodic_embedding_idx
  ON episodic_memory USING hnsw (embedding vector_cosine_ops)
  WITH (m = 16, ef_construction = 64);

-- Retrieval index
CREATE INDEX episodic_session_idx
  ON episodic_memory (session_id, created_at DESC)
  WHERE deleted_at IS NULL AND archived_at IS NULL;
```

### Embedding pipeline
Embeddings are generated asynchronously — the chat response does not wait for them:

```python
async def save_turn(self, session_id: str, user_msg: str, assistant_msg: str):
    # 1. Insert entry with embedding = NULL (fast path)
    entry = EpisodicMemory(session_id=session_id, role="user", content=user_msg)
    db.add(entry)
    await db.commit()

    # 2. Generate embedding in background (does not block response)
    asyncio.create_task(self._embed_and_update(entry.id, user_msg))
```

### Retrieval query
```python
async def retrieve_relevant(
    self, session_id: str, query: str, k: int = 5
) -> list[EpisodicMemory]:
    query_embedding = await self.embed(query)
    result = await db.execute(
        select(EpisodicMemory)
        .where(EpisodicMemory.deleted_at.is_(None))
        .where(EpisodicMemory.archived_at.is_(None))
        .where(EpisodicMemory.embedding.isnot(None))
        .order_by(
            EpisodicMemory.embedding.cosine_distance(query_embedding)
        )
        .limit(k)
    )
    return result.scalars().all()
```

