## State Management (Zustand)

One store per domain. Keep stores flat — no nested state that mutates partially.

```typescript
// src/stores/chatStore.ts
import { create } from "zustand"

export interface Message {
  id: string
  role: "user" | "assistant"
  content: string
  provider?: string
  fallbackFrom?: string
  isStreaming?: boolean
  error?: string
  createdAt: Date
}

interface ChatStore {
  messages: Message[]
  sessionId: string
  isConnected: boolean
  addMessage:    (msg: Omit<Message, "id" | "createdAt">) => void
  appendToken:   (delta: string) => void
  finalizeMsg:   (provider: string) => void
  setConnected:  (v: boolean) => void
  clearMessages: () => void
}

export const useChatStore = create<ChatStore>((set) => ({
  messages:   [],
  sessionId:  crypto.randomUUID(),
  isConnected: false,

  addMessage: (msg) => set((s) => ({
    messages: [...s.messages, {
      ...msg,
      id: crypto.randomUUID(),
      createdAt: new Date(),
    }],
  })),

  appendToken: (delta) => set((s) => {
    const msgs = [...s.messages]
    const last = msgs[msgs.length - 1]
    if (last?.isStreaming) {
      msgs[msgs.length - 1] = { ...last, content: last.content + delta }
    }
    return { messages: msgs }
  }),

  finalizeMsg: (provider) => set((s) => {
    const msgs = [...s.messages]
    const last = msgs[msgs.length - 1]
    if (last?.isStreaming) {
      msgs[msgs.length - 1] = { ...last, isStreaming: false, provider }
    }
    return { messages: msgs }
  }),

  setConnected:  (isConnected) => set({ isConnected }),
  clearMessages: () => set({ messages: [] }),
}))
```

