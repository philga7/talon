## SSE Hook

The SSE connection is the most critical piece of the frontend.
It must auto-reconnect on drop with exponential backoff.

```typescript
// src/hooks/useSSE.ts
import { useEffect, useRef, useState, useCallback } from "react"

export type SSEEvent =
  | { type: "token";       delta: string }
  | { type: "tool_start";  name: string; input: Record<string, unknown> }
  | { type: "tool_result"; name: string; output: unknown; success: boolean }
  | { type: "done";        session_id: string }
  | { type: "error";       message: string; recoverable: boolean }

interface UseSSEOptions {
  onEvent: (event: SSEEvent) => void
  maxRetries?: number
}

export function useSSE(sessionId: string, options: UseSSEOptions) {
  const [connected, setConnected] = useState(false)
  const [reconnectCount, setReconnectCount] = useState(0)
  const esRef = useRef<EventSource | null>(null)
  const retryRef = useRef<ReturnType<typeof setTimeout>>()
  const retriesRef = useRef(0)
  const maxRetries = options.maxRetries ?? 10

  const connect = useCallback(() => {
    if (esRef.current) esRef.current.close()

    const es = new EventSource(`/api/sse/${sessionId}`)
    esRef.current = es

    es.onopen = () => {
      setConnected(true)
      retriesRef.current = 0
      setReconnectCount(0)
    }

    es.onmessage = (e) => {
      try {
        options.onEvent(JSON.parse(e.data) as SSEEvent)
      } catch {
        // malformed event — log and continue
      }
    }

    es.onerror = () => {
      setConnected(false)
      es.close()
      if (retriesRef.current < maxRetries) {
        const delay = Math.min(1000 * 2 ** retriesRef.current, 30_000)
        retryRef.current = setTimeout(() => {
          retriesRef.current++
          setReconnectCount((n) => n + 1)
          connect()
        }, delay)
      }
    }
  }, [sessionId, maxRetries, options])

  useEffect(() => {
    connect()
    return () => {
      esRef.current?.close()
      clearTimeout(retryRef.current)
    }
  }, [connect])

  return { connected, reconnectCount }
}
```

