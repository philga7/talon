## Component Conventions

### File organization

```
src/components/
  chat/
    ChatWindow.tsx       # Container: owns layout
    MessageList.tsx      # Dumb: renders array of messages
    MessageBubble.tsx    # Dumb: renders single message
    ChatInput.tsx        # Smart: owns input state + send handler
    __tests__/
      MessageBubble.test.tsx
  health/
    HealthDashboard.tsx
    ProviderCard.tsx
  memory/
    MemoryViewer.tsx
  shared/
    Spinner.tsx
    ErrorBanner.tsx
    Badge.tsx
```

Rules:
- Colocate tests in `__tests__/` adjacent to the component
- One component per file
- Named exports only — no default exports (makes refactoring easier)

### Component template

```tsx
import type { FC } from "react"

interface MessageBubbleProps {
  role: "user" | "assistant"
  content: string
  provider?: string
  fallbackFrom?: string
  error?: string
}

export const MessageBubble: FC<MessageBubbleProps> = ({
  role,
  content,
  provider,
  fallbackFrom,
  error,
}) => {
  if (error) {
    return (
      <div role="alert" className="alert alert-error">
        {error}
      </div>
    )
  }

  return (
    <div className={`chat ${role === "user" ? "chat-end" : "chat-start"}`}>
      <div className="chat-bubble">
        {content}
        {provider && (
          <span className="badge badge-ghost badge-xs ml-2">{provider}</span>
        )}
        {fallbackFrom && (
          <span data-testid="fallback-badge" className="badge badge-warning badge-xs ml-1">
            fallback from {fallbackFrom}
          </span>
        )}
      </div>
    </div>
  )
}
```

