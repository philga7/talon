## HTTP Pattern for Skills

Always use `httpx.AsyncClient`. Always set timeouts. Always handle errors.

```python
import httpx
from app.skills.base import BaseSkill, ToolDefinition, SkillResult

class WeatherSkill(BaseSkill):
    name = "weather_enhanced"
    version = "1.0.0"

    BASE_URL = "https://api.weatherapi.com/v1"

    def __init__(self):
        self._api_key: str | None = None

    async def on_load(self):
        # Load secrets at startup, not at module level
        key_path = Path("config/secrets/weather_api_key")
        if key_path.exists():
            self._api_key = key_path.read_text().strip()

    def health_check(self) -> bool:
        return self._api_key is not None

    @property
    def tools(self) -> list[ToolDefinition]:
        return [
            ToolDefinition(
                name="get_current_weather",
                description=(
                    "Get current weather conditions including temperature, humidity, "
                    "wind speed, and conditions for any city or location. Use when the "
                    "user asks about current weather or conditions in a place."
                ),
                parameters={
                    "type": "object",
                    "properties": {
                        "location": {
                            "type": "string",
                            "description": "City name, e.g. 'Atlanta, GA' or 'London, UK'"
                        }
                    }
                },
                required=["location"]
            )
        ]

    async def execute(self, tool_name: str, params: dict) -> SkillResult:
        match tool_name:
            case "get_current_weather":
                return await self._current_weather(params["location"])
            case _:
                return SkillResult(tool_name=tool_name, success=False,
                                   data=None, error=f"Unknown tool: {tool_name}")

    async def _current_weather(self, location: str) -> SkillResult:
        try:
            async with httpx.AsyncClient(timeout=10.0) as client:
                resp = await client.get(
                    f"{self.BASE_URL}/current.json",
                    params={"key": self._api_key, "q": location, "aqi": "no"},
                )
                resp.raise_for_status()
                data = resp.json()
                current = data["current"]
                return SkillResult(
                    tool_name="get_current_weather",
                    success=True,
                    data={
                        "location": data["location"]["name"],
                        "temp_f": current["temp_f"],
                        "temp_c": current["temp_c"],
                        "condition": current["condition"]["text"],
                        "humidity": current["humidity"],
                        "wind_mph": current["wind_mph"],
                    }
                )
        except httpx.TimeoutException:
            return SkillResult(tool_name="get_current_weather", success=False,
                               data=None, error="Weather API timed out")
        except httpx.HTTPStatusError as e:
            return SkillResult(tool_name="get_current_weather", success=False,
                               data=None, error=f"Weather API error: {e.response.status_code}")
        except (KeyError, ValueError) as e:
            return SkillResult(tool_name="get_current_weather", success=False,
                               data=None, error=f"Unexpected response shape: {e}")
```

