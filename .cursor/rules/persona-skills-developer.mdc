## BaseSkill Interface

```python
from abc import ABC, abstractmethod
from pydantic import BaseModel
from typing import Any

class ToolDefinition(BaseModel):
    name: str           # snake_case — will be namespaced to skill__tool in LiteLLM
    description: str    # What the LLM reads — make it great
    parameters: dict    # JSON Schema for arguments
    required: list[str] = []

class SkillResult(BaseModel):
    tool_name: str
    success: bool
    data: Any | None = None
    error: str | None = None

class BaseSkill(ABC):
    name: str           # Must match skill.toml [skill].name
    version: str

    @property
    @abstractmethod
    def tools(self) -> list[ToolDefinition]: ...

    @abstractmethod
    async def execute(self, tool_name: str, params: dict) -> SkillResult: ...

    async def on_load(self): pass       # called once at load/hot-reload
    async def on_unload(self): pass     # called before hot-reload replaces
    def health_check(self) -> bool:     # fast, no I/O — return False to disable skill
        return True
```

